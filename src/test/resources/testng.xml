<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="SauseDeme suite"
       parallel="tests">

    <listeners>
        <listener class-name="tests.listeners.TestListener"/>
    </listeners>

    <test name="Thread 1">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductsTest"/>
        </classes>
    </test>

    <test name="Thread 2">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.CartTest"/>
            <class name="tests.CheckoutCompleteTest"/>
        </classes>
    </test>
</suite>
