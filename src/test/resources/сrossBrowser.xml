<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="SauseDeme suite"
       parallel="tests">

    <listeners>
        <listener class-name="tests.listeners.RetryListener"/>
        <listener class-name="tests.listeners.TestListener"/>
    </listeners>

    <test name="Chrome">
        <classes>
            <class name="tests.LoginTest"/>
            <class name="tests.ProductsTest"/>
            <class name="tests.CartTest"/>
            <parameter name="browser" value="chrome"></parameter>
        </classes>
    </test>

    <test name="Edge">
        <classes>
            <class name="tests.CheckoutCompleteTest"/>
            <class name="tests.CheckoutOverviewTest"/>
            <class name="tests.CheckoutTest"/>
            <parameter name="browser" value="edge"></parameter>
        </classes>
    </test>
</suite>
